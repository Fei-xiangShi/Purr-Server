POSTGRES_DB=purr
POSTGRES_USER=purr
POSTGRES_PASSWORD=change-me-postgres-password

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_BUCKET=purr-recordings
MINIO_REGION=us-east-1

LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_NODE_IP=YOUR_SERVER_PUBLIC_IP

PURR_AUTH_JWT_SECRET=change-me-jwt-secret
PURR_AUTH_USER_A_PASSWORD=change-me-user-a-password
PURR_AUTH_USER_B_PASSWORD=change-me-user-b-password

# Single-domain deployment: expose LiveKit to mobile clients under the same public domain.
# Example reverse proxy target: wss://purr.fxs.life/livekit -> livekit:7880
PURR_LIVEKIT_WS_URL=wss://purr.fxs.life/livekit
