# 下面这一行配置 PostgreSQL 使用的数据库名
POSTGRES_DB=purr
# 下面这一行配置 PostgreSQL 登录用户名
POSTGRES_USER=purr
# 下面这一行配置 PostgreSQL 登录密码，部署前必须改成你自己的强密码
POSTGRES_PASSWORD=change-me-postgres-password

# 下面这一行配置 MinIO 管理员账号
MINIO_ROOT_USER=minioadmin
# 下面这一行配置 MinIO 管理员密码，部署前必须改成你自己的强密码
MINIO_ROOT_PASSWORD=change-me-minio-password
# 下面这一行配置录音文件写入的桶名
MINIO_BUCKET=purr-recordings
# 下面这一行配置 MinIO / S3 区域名，通常保留 us-east-1 即可
MINIO_REGION=us-east-1

# 下面这一行配置 LiveKit API Key，必须与 compose 里注入给 livekit / egress / purr-server 的值一致
LIVEKIT_API_KEY=devkey
# 下面这一行配置 LiveKit API Secret，必须与 compose 里注入给 livekit / egress / purr-server 的值一致
LIVEKIT_API_SECRET=devsecret
# 下面这一行配置服务器公网 IPv4，供 LiveKit 对外通告 RTC 地址
LIVEKIT_NODE_IP=YOUR_SERVER_PUBLIC_IP

# 下面这一行配置 purr-server 登录 JWT 的签名密钥，部署前必须改成随机长串
PURR_AUTH_JWT_SECRET=change-me-jwt-secret

# 下面这一行配置固定账号 A 的内部 userId
PURR_AUTH_USER_A_ID=user-a
# 下面这一行配置固定账号 A 的登录用户名
PURR_AUTH_USER_A_USERNAME=user-a
# 下面这一行配置固定账号 A 的显示名
PURR_AUTH_USER_A_DISPLAY_NAME=Purr Alpha
# 下面这一行配置固定账号 A 的头像 URL，可留空
PURR_AUTH_USER_A_AVATAR_URL=
# 下面这一行配置固定账号 A 的登录密码，部署前必须改成你自己的密码
PURR_AUTH_USER_A_PASSWORD=change-me-user-a-password

# 下面这一行配置固定账号 B 的内部 userId
PURR_AUTH_USER_B_ID=user-b
# 下面这一行配置固定账号 B 的登录用户名
PURR_AUTH_USER_B_USERNAME=user-b
# 下面这一行配置固定账号 B 的显示名
PURR_AUTH_USER_B_DISPLAY_NAME=Purr Beta
# 下面这一行配置固定账号 B 的头像 URL，可留空
PURR_AUTH_USER_B_AVATAR_URL=
# 下面这一行配置固定账号 B 的登录密码，部署前必须改成你自己的密码
PURR_AUTH_USER_B_PASSWORD=change-me-user-b-password

# 下面这一行配置固定配对的 pairId
PURR_PAIR_ID=pair-demo
# 下面这一行配置固定配对建立时间戳（毫秒）
PURR_PAIR_BONDED_AT_EPOCH_MILLIS=1735689600000
# 下面这一行配置配对中的 A 端 userId，必须与上面的 PURR_AUTH_USER_A_ID 一致
PURR_PAIR_USER_A_ID=user-a
# 下面这一行配置配对中的 B 端 userId，必须与上面的 PURR_AUTH_USER_B_ID 一致
PURR_PAIR_USER_B_ID=user-b

# 下面这一行配置返回给 Android 客户端的 LiveKit 公网 WebSocket 地址
# 单域名部署示例：wss://your-domain.example/livekit
PURR_LIVEKIT_WS_URL=wss://your-domain.example/livekit
